# Vapi — voice agent for outbound restaurant calls
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_MODEL_PROVIDER=openai
VAPI_MODEL_NAME=gpt-4.1
VAPI_VOICE_PROVIDER=11labs
VAPI_VOICE_ID=sarah
VAPI_VOICE_MODEL=eleven_turbo_v2_5
VAPI_VOICE_OPTIMIZE_STREAMING_LATENCY=3

# Google Places — restaurant search and details
GOOGLE_PLACES_API_KEY=

# Supabase — database + realtime
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini — transcript extraction (free tier: 15 RPM, 1M tokens/day)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
